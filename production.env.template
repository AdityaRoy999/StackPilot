# Copy this file to .env on a production VPS and replace every placeholder.
# Generate secrets with: openssl rand -base64 48

STACKPILOT_ENV=production
STACKPILOT_DOMAIN=stackpilot.example.com
STACKPILOT_CADDY_SITE_ADDRESS=stackpilot.example.com
ACME_EMAIL=admin@example.com
STACKPILOT_HTTP_PORT=80
STACKPILOT_HTTPS_PORT=443
APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=StackPilot Platform

DB_USER=stackpilot_admin
DB_PASSWORD=replace-with-a-long-random-database-password
DB_NAME=stackpilot_platform

JWT_SECRET=replace-with-at-least-48-random-characters
JWT_EXPIRY_SECONDS=3600
TOKEN_ENCRYPTION_KEY=replace-with-at-least-48-random-characters

CORS_ALLOWED_ORIGIN=https://stackpilot.example.com
FRONTEND_PUBLIC_URL=https://stackpilot.example.com
BACKEND_PUBLIC_URL=https://stackpilot.example.com
STACKPILOT_REQUIRE_HTTPS=true
STACKPILOT_TRUST_PROXY_HEADERS=true
STACKPILOT_API_RATE_LIMIT_PER_MINUTE=240
STACKPILOT_AUTH_REGISTRATION_MODE=first_user_only
STACKPILOT_AUTH_INVITE_CODE=

NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_WS_BASE_URL=wss://stackpilot.example.com

# Optional OAuth providers.
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CALLBACK_URL=
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret
GITHUB_APP_WEBHOOK_MODE=false
GITHUB_APP_NAME=StackPilot
GITHUB_APP_SLUG=
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_PRIVATE_KEY_BASE64=
# Leave these empty for GitHub to use the OAuth app callback URL.
# Set both only when StackPilot must send an explicit redirect_uri to GitHub.
GITHUB_OAUTH_REDIRECT_URL=
GITHUB_FORCE_REDIRECT_URI=false

# Build/runtime guardrails.
BUILD_MAX_LOG_BYTES=200000
BUILD_CLONE_TIMEOUT_SECONDS=300
BUILD_COMMAND_TIMEOUT_SECONDS=3600
BUILD_DOCKER_MEMORY=1g
STACKPILOT_BACKEND_BUILD_PARALLELISM=1
STACKPILOT_COMPOSE_PARALLEL_LIMIT=1
STACKPILOT_CI_NO_CHECKS_GRACE_SECONDS=30
STACKPILOT_LOCAL_PROJECTS_DIR=./local-projects
LOCAL_SOURCE_ROOTS=/app/local-projects

# Kubernetes defaults. Ingress is production-friendly when a controller is installed.
K8S_NAMESPACE=stackpilot-apps
K8S_SERVICE_TYPE=NodePort
K8S_EXPOSURE_MODE=ingress
K8S_NODE_HOST=localhost
K8S_BASE_DOMAIN=
K8S_RUNTIME_SCHEME=https
K8S_INGRESS_CLASS=nginx
K8S_CERT_CLUSTER_ISSUER=letsencrypt-prod
K8S_INGRESS_TLS_SECRET=
K8S_INGRESS_ANNOTATIONS_JSON=
REMOTE_K8S_BASE_DOMAIN=
REMOTE_K8S_INGRESS_CLASS=auto
REMOTE_K8S_CERT_CLUSTER_ISSUER=letsencrypt-prod
REMOTE_K8S_CERT_MANAGER_VERSION=v1.15.3
K8S_NAMESPACE_PREFIX=
K8S_IMAGE_PULL_SECRET=
K8S_SERVICE_ACCOUNT_NAME=
K8S_ENABLE_PDB=true
K8S_ENABLE_HPA=false
K8S_HPA_MIN_REPLICAS=1
K8S_HPA_MAX_REPLICAS=3
K8S_HPA_CPU_UTILIZATION=70
K8S_MAX_REPLICAS=10
K8S_CPU_REQUEST=100m
K8S_MEMORY_REQUEST=128Mi
K8S_CPU_LIMIT=500m
K8S_MEMORY_LIMIT=512Mi
K8S_PROBE_PATH=/
K8S_READINESS_INITIAL_DELAY_SECONDS=5
K8S_LIVENESS_INITIAL_DELAY_SECONDS=15
K8S_STARTUP_FAILURE_THRESHOLD=30
K8S_ROLLOUT_TIMEOUT_SECONDS=180
KUBECONFIG_PATH=/root/.kube/config
KUBECONFIG_HOST_PATH=/etc/stackpilot/kubeconfig

# Logging and monitoring.
STACKPILOT_LOG_MAX_SIZE=10m
STACKPILOT_LOG_MAX_FILE=5
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
LOKI_PORT=3100
CADVISOR_PORT=8081
PROMETHEUS_RETENTION=15d
PROMETHEUS_PUBLIC_URL=
GRAFANA_PUBLIC_URL=https://stackpilot.example.com/grafana
LOKI_PUBLIC_URL=https://stackpilot.example.com/grafana/explore
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-long-random-grafana-password
STACKPILOT_METRICS_BEARER_TOKEN=

# AI agent service.
# NVIDIA NIM is the default provider. Set STACKPILOT_AI_PROVIDER=openai_compatible
# to use any OpenAI-compatible chat/completions API.
STACKPILOT_AI_ENABLED=true
STACKPILOT_AI_PROVIDER=nvidia_nim
STACKPILOT_AI_MODEL=
STACKPILOT_AI_CONFIDENCE_THRESHOLD=0.72
STACKPILOT_AI_RATE_LIMIT_PER_MINUTE=12
STACKPILOT_AI_MAX_CONTEXT_BYTES=32000
STACKPILOT_AI_SERVICE_TIMEOUT_SECONDS=120
STACKPILOT_AI_REQUEST_TIMEOUT_SECONDS=90
STACKPILOT_AI_MAX_TEXT_BYTES=24000
STACKPILOT_AI_SERVICE_PORT=8010
NVIDIA_API_KEY=
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_NIM_FAST_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_NIM_THINKING_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_NIM_ALLOWED_MODELS=
NVIDIA_NIM_DISCOVER_MODELS=true
NVIDIA_NIM_PROBE_MODELS=true
NVIDIA_NIM_MODEL_PROBE_LIMIT=100
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_THINKING_MODEL=
